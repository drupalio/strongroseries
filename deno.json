{
  "lint": {
    "exclude": ["web/", "tests/", "vendor/", "docs/", "specs/"]
  },
  "fmt": {
    "exclude": ["vendor/"]
  },
  "tasks": {
    "dev": "deno run --watch --allow-net main.ts",
    "test": "deno test --allow-read --allow-env",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "check": "deno check main.ts",
    "coverage": "deno test --coverage --allow-read --allow-env && deno coverage",
    "bench": "deno bench",
    "desktop": "deno desktop --include web --allow-net --allow-env --allow-read --allow-write --allow-ffi --allow-run main.ts",
    "desktop:hmr": "deno desktop --hmr --include web --allow-net --allow-env --allow-read --allow-write --allow-ffi --allow-run main.ts",
    "build": "bash scripts/build-desktop.sh"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@db/sqlite": "jsr:@db/sqlite@0.13.0",
    "exceljs": "npm:exceljs@^4.4.0",
    "pdfkit": "npm:pdfkit@^0.19.1",
    "sql.js": "npm:sql.js@1.14.1",
    "@logtape/logtape": "jsr:@logtape/logtape@^0.8.0",
    "zod": "npm:zod@^3.24.0",
    "croner": "npm:croner@^9.0.0"
  }
}
